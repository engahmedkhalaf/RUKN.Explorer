<Window x:Class="RUKN.Search.Plugin.ModelProcessingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True"
        Background="{x:Null}"
        mc:Ignorable="d"
        Width="350"
        Height="640"
        MinWidth="350"
        MinHeight="400"
        Title="Model Processing"
        ResizeMode="CanResize"
        Topmost="False"
        ShowInTaskbar="True"
        Closing="Window_Closing"
        Style="{DynamicResource CustomWindowStyle}">

    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="Close" />
    </Window.InputBindings>

    <Window.CommandBindings>
        <CommandBinding Command="Close" Executed="Close_Button" />
    </Window.CommandBindings>

    <Border x:Name="MainWindow_Border"
            Background="{DynamicResource BackgroundColor}"
            BorderBrush="Transparent"
            BorderThickness="1"
            CornerRadius="15"
            Margin="10"
            MouseDown="Border_MouseDown">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Color="Gray" Opacity="0.3" ShadowDepth="0" Direction="0" />
        </Border.Effect>

        <Grid Background="Transparent" RenderOptions.BitmapScalingMode="HighQuality" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- Header -->
                <RowDefinition Height="Auto" /> <!-- Separator -->
                <RowDefinition Height="*" />    <!-- Content Area -->
                <RowDefinition Height="Auto" /> <!-- Action Buttons -->
                <RowDefinition Height="Auto" /> <!-- Status Bar -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,-4,0,10">
                <Button Click="Ruknbim_Link"
                        Background="Transparent"
                        BorderThickness="0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <ContentPresenter />
                        </ControlTemplate>
                    </Button.Template>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="/RUKN.Explorer;component/Resources/SelectByRevitId.png"
                               Height="28"
                               Stretch="Uniform"
                               SnapsToDevicePixels="True"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                        <TextBlock Text="MODEL PROCESSING" 
                                   Foreground="#18263c" 
                                   FontWeight="Bold" 
                                   FontSize="16" 
                                   VerticalAlignment="Center" 
                                   Margin="10,0,0,0"/>
                    </StackPanel>
                </Button>

                <Button Style="{DynamicResource TabCloseButtonStyle}"
                        Name="CloseButton"
                        Click="Close_Button"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center" />
            </Grid>

            <!-- Separator Line -->
            <Line Grid.Row="1" 
                  Stroke="{DynamicResource MainGray}"
                  X2="1000"
                  Opacity="0.3"
                  StrokeThickness="2"
                  Margin="-20,0,-20,15" />

            <!-- Content Area -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="0,0,10,0">
                    
                    <!-- Model Source Group -->
                    <TextBlock Text="Model Source" FontWeight="Bold" Foreground="#18263c" FontSize="13" Margin="0,0,0,5"/>
                    <Border BorderBrush="{DynamicResource SecondaryGray}" BorderThickness="0,0,0,1" Opacity="0.3" Margin="0,0,0,10"/>
                    <StackPanel Margin="10,0,0,15">
                        <ComboBox Name="ComboModel" SelectionChanged="ComboModel_SelectionChanged" Height="28" HorizontalAlignment="Stretch"/>
                    </StackPanel>

                    <!-- Reference Settings Group -->
                    <TextBlock Text="Reference Settings" FontWeight="Bold" Foreground="#18263c" FontSize="13" Margin="0,0,0,5"/>
                    <Border BorderBrush="{DynamicResource SecondaryGray}" BorderThickness="0,0,0,1" Opacity="0.3" Margin="0,0,0,10"/>
                    <Grid Margin="10,0,0,15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Units -->
                        <TextBlock Text="Units:" VerticalAlignment="Top" Margin="0,5,0,0" Grid.Row="0" Grid.Column="0"/>
                        <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="1" Margin="0,5,0,0">
                            <RadioButton Name="RadioMM" GroupName="UnitGroup" Content="mm" Margin="0,0,15,0" Checked="Unit_Checked" />
                            <RadioButton Name="RadioCM" GroupName="UnitGroup" Content="cm" Margin="0,0,15,0" Checked="Unit_Checked" />
                            <RadioButton Name="RadioM" GroupName="UnitGroup" Content="m" IsChecked="True" Margin="0,0,15,0" Checked="Unit_Checked" />
                            <RadioButton Name="RadioFT" GroupName="UnitGroup" Content="ft" Checked="Unit_Checked" />
                        </StackPanel>
                    </Grid>

                    <!-- Section Cut Group -->
                    <TextBlock Text="Section Cut" FontWeight="Bold" Foreground="#18263c" FontSize="13" Margin="0,0,0,5"/>
                    <Border BorderBrush="{DynamicResource SecondaryGray}" BorderThickness="0,0,0,1" Opacity="0.3" Margin="0,0,0,10"/>
                    <Grid Margin="10,0,0,15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Offset Top Z -->
                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,0">
                            <CheckBox Name="CheckOffsetTop" Content="Offset Top Z" IsChecked="True" VerticalAlignment="Center" Margin="0,0,0,5"/>
                            <StackPanel Orientation="Horizontal" Margin="20,0,0,0">
                                <TextBlock Text="Amount:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBox Name="TextOffsetTop" Text="-2" Width="60" Height="28" Padding="5,2" VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Offset Bottom Z -->
                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,10,0">
                            <CheckBox Name="CheckOffsetBottom" Content="Offset Bottom Z" IsChecked="True" VerticalAlignment="Center" Margin="0,0,0,5"/>
                            <StackPanel Orientation="Horizontal" Margin="20,0,0,0">
                                <TextBlock Text="Amount:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBox Name="TextOffsetBottom" Text="-5" Width="60" Height="28" Padding="5,2" VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <!-- Apply To Group -->
                    <TextBlock Text="Apply To" FontWeight="Bold" Foreground="#18263c" FontSize="13" Margin="0,0,0,5"/>
                    <Border BorderBrush="{DynamicResource SecondaryGray}" BorderThickness="0,0,0,1" Opacity="0.3" Margin="0,0,0,10"/>
                    <StackPanel Margin="10,0,0,15">
                        <RadioButton GroupName="ApplyToGroup" Content="All Levels" Margin="0,0,0,8" />
                        <RadioButton GroupName="ApplyToGroup" Content="Selected Levels" IsChecked="True" Margin="0,0,0,8" />
                    </StackPanel>

                    <!-- Levels Group -->
                    <TextBlock Text="Levels" FontWeight="Bold" Foreground="#18263c" FontSize="13" Margin="0,0,0,5"/>
                    <Border BorderBrush="{DynamicResource SecondaryGray}" BorderThickness="0,0,0,1" Opacity="0.3" Margin="0,0,0,10"/>
                    <Border Background="#F4F7FA" CornerRadius="8" BorderBrush="#E0E6ED" BorderThickness="1" Margin="10,0,0,10">
                        <StackPanel Name="PanelLevels" Margin="12,10">
                        </StackPanel>
                    </Border>
                    
                </StackPanel>
            </ScrollViewer>

            <!-- Action Buttons Grid -->
            <Grid Grid.Row="3" Margin="0,15,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Button Style="{DynamicResource ApplyButtonStyle}" 
                        Content="Generate Viewpoints" 
                        Click="GenerateViewpoints_Click"
                        Height="34" 
                        Margin="0,0,5,8"
                        Grid.Row="0" Grid.Column="0"/>
                
                <Button Style="{DynamicResource ApplyButtonStyle}" 
                        Content="Read Models" 
                        Click="ReadModels_Click"
                        Height="34" 
                        Margin="5,0,0,8"
                        Grid.Row="0" Grid.Column="1"/>

                <Button Style="{DynamicResource ApplyButtonStyle}" 
                        Content="Clear Saved Views" 
                        Click="ClearSavedViews_Click"
                        Height="34" 
                        Margin="0,0,5,8"
                        Grid.Row="1" Grid.Column="0"/>

                <Button Style="{DynamicResource ApplyButtonStyle}" 
                        Content="Export Data" 
                        Click="ExportData_Click"
                        Height="34" 
                        Margin="5,0,0,8"
                        Grid.Row="1" Grid.Column="1"/>

                <Button Style="{DynamicResource ApplyButtonStyle}" 
                        Content="Reset to Full Mode" 
                        Click="ResetFullMode_Click"
                        Height="34" 
                        Margin="0,0,0,0"
                        Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"/>
            </Grid>

            <!-- Status Bar -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,5,0,0">
                <TextBlock Text="Status: " Foreground="{DynamicResource SecondaryGray}" FontSize="12"/>
                <TextBlock Name="TextBlockStatus" Text="Ready..." Foreground="#1b6ece" FontWeight="SemiBold" FontSize="12"/>
            </StackPanel>

        </Grid>
    </Border>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="./Resources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
</Window>
