<Window x:Class="RUKN.InsightPro.Plugin.Windows.LicenseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RUKN Insight Pro - License Manager"
        Width="420" SizeToContent="Height"
        Background="#0B0F19"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Topmost="True"
        WindowStyle="SingleBorderWindow"
        FontFamily="Segoe UI"
        Loaded="Window_Loaded">

    <Window.Resources>
        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RoundedTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#1F2937"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#3B82F6"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InfoLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="InfoValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
    </Window.Resources>

    <Grid Margin="25,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Cursor="Hand" MouseLeftButtonDown="Website_Click" ToolTip="www.ruknbim.com">
                <TextBlock Text="RUKN Insight Pro" Foreground="White" FontSize="18" FontWeight="Bold"/>
                <TextBlock Text="License Manager" Foreground="#6B7280" FontSize="11" FontWeight="SemiBold"/>
            </StackPanel>
            <Border Grid.Column="1" Background="#070A13" BorderBrush="#1F2937" BorderThickness="1" CornerRadius="4" Padding="8,4" VerticalAlignment="Center"
                    Cursor="Hand" MouseLeftButtonDown="Website_Click" ToolTip="www.ruknbim.com">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="RUKN" Foreground="White" FontWeight="Bold" FontSize="11"/>
                    <TextBlock Text="BIM" Foreground="#3A86FF" FontWeight="Bold" FontSize="11"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- License Status Panel -->
        <Border Grid.Row="1" Background="#0F1524" BorderBrush="#1F2937" BorderThickness="1" CornerRadius="8" Padding="15,12" Margin="0,20,0,0">
            <StackPanel>
                <!-- Status -->
                <Grid Margin="0,0,0,10">
                    <TextBlock Text="License Status" Style="{StaticResource InfoLabelStyle}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Ellipse x:Name="StatusDot" Width="9" Height="9" Fill="#6B7280" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock x:Name="StatusText" Text="Checking..." Style="{StaticResource InfoValueStyle}"/>
                    </StackPanel>
                </Grid>

                <!-- Email -->
                <Grid x:Name="EmailRow" Margin="0,0,0,10" Visibility="Collapsed">
                    <TextBlock Text="Email" Style="{StaticResource InfoLabelStyle}"/>
                    <TextBlock x:Name="EmailText" Style="{StaticResource InfoValueStyle}" MaxWidth="230"/>
                </Grid>

                <!-- Days Remaining (trial only) -->
                <Grid x:Name="DaysRow" Margin="0,0,0,10" Visibility="Collapsed">
                    <TextBlock Text="Days Remaining" Style="{StaticResource InfoLabelStyle}"/>
                    <TextBlock x:Name="DaysText" Style="{StaticResource InfoValueStyle}" Foreground="#22C55E"/>
                </Grid>

                <!-- License Type (activated only) -->
                <Grid x:Name="TypeRow" Margin="0,0,0,10" Visibility="Collapsed">
                    <TextBlock Text="License Type" Style="{StaticResource InfoLabelStyle}"/>
                    <TextBlock x:Name="TypeText" Style="{StaticResource InfoValueStyle}"/>
                </Grid>

                <!-- Expiry (label switches: Trial Expiry / Expiry Date / Expired On) -->
                <Grid x:Name="ExpiryRow" Margin="0,0,0,10" Visibility="Collapsed">
                    <TextBlock x:Name="ExpiryLabel" Text="Expiry Date" Style="{StaticResource InfoLabelStyle}"/>
                    <TextBlock x:Name="ExpiryText" Style="{StaticResource InfoValueStyle}"/>
                </Grid>

                <!-- License Key (activated only) -->
                <Grid x:Name="KeyRow" Margin="0,0,0,10" Visibility="Collapsed">
                    <TextBlock Text="License Key" Style="{StaticResource InfoLabelStyle}"/>
                    <TextBlock x:Name="KeyText" Style="{StaticResource InfoValueStyle}"/>
                </Grid>

                <!-- Machine (shortened) -->
                <Grid x:Name="MachineRow" Visibility="Collapsed">
                    <TextBlock Text="Machine" Style="{StaticResource InfoLabelStyle}"/>
                    <TextBlock x:Name="MachineText" Style="{StaticResource InfoValueStyle}" Foreground="#9CA3AF" FontWeight="Normal"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Activation Section (hidden when license is active/paid) -->
        <StackPanel Grid.Row="2" x:Name="ActivationPanel" Margin="0,18,0,0" Visibility="Collapsed">
            <TextBlock Text="License Key" Foreground="#9CA3AF" FontSize="11" Margin="0,0,0,5"/>
            <TextBox x:Name="KeyInput" Style="{StaticResource RoundedTextBoxStyle}" Height="32" VerticalContentAlignment="Center" CharacterCasing="Upper"/>
            <Button x:Name="BtnActivate" Content="Activate License" Style="{StaticResource RoundedButtonStyle}"
                    Background="#2563EB" Foreground="White" BorderThickness="0" Height="36" FontSize="13" FontWeight="Bold"
                    Margin="0,12,0,0" Click="BtnActivate_Click"/>

            <!-- Sign out / re-register with another email (trial only) -->
            <StackPanel x:Name="SignOutPanel" Margin="0,16,0,0" Visibility="Collapsed">
                <TextBlock Text="You can sign out to clear this computer's registration. Re-registering requires the same email."
                           Foreground="#6B7280" FontSize="10.5" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,8"/>
                <Button x:Name="BtnSignOut" Content="Sign Out" Style="{StaticResource RoundedButtonStyle}"
                        Background="#1E293B" Foreground="White" Height="30" FontSize="12" FontWeight="SemiBold"
                        Width="180" Click="BtnSignOut_Click"/>
            </StackPanel>
        </StackPanel>

        <!-- Active Badge (shown when license is paid & valid) -->
        <StackPanel Grid.Row="3" x:Name="ActivePanel" Margin="0,18,0,0" Visibility="Collapsed">
            <Border x:Name="ActiveBadge" Background="#062E1A" BorderBrush="#14532D" BorderThickness="1"
                    CornerRadius="8" Padding="10">
                <TextBlock Text="✓  License Active" Foreground="#22C55E" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center"/>
            </Border>
            <Button x:Name="BtnDeactivate" Content="Deactivate on This Machine" Style="{StaticResource RoundedButtonStyle}"
                    Background="#2D1215" Foreground="#F87171" BorderBrush="#7F1D1D" BorderThickness="1"
                    Height="32" FontSize="12" FontWeight="SemiBold" Margin="0,10,0,0" Click="BtnDeactivate_Click"
                    ToolTip="Releases this license so it can be activated on another computer"/>
        </StackPanel>

        <!-- Footer -->
        <Grid Grid.Row="4" Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" x:Name="SalesPanel" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Need a license? " Foreground="#9CA3AF" FontSize="11"/>
                <TextBlock Text="sales@ruknbim.com" Foreground="#3A86FF" FontSize="11" FontWeight="SemiBold"
                           Cursor="Hand" TextDecorations="Underline" MouseLeftButtonDown="SupportLink_Click"/>
            </StackPanel>

            <Button Grid.Column="1" x:Name="BtnClose" Content="Close" Style="{StaticResource RoundedButtonStyle}"
                    Background="#1E293B" Foreground="White" Width="70" Height="26" Click="BtnClose_Click"/>
        </Grid>
    </Grid>
</Window>
