<Window x:Class="RUKN.Quant.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="RUKN Quant - Quantity Extraction"
        Height="650" Width="1000"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F9"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Modern Scrollbar Styling -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>

        <!-- Premium Button Styles -->
        <Style x:Key="HeaderButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1B6ECE"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1556A3"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ExcelButtonStyle" TargetType="Button" BasedOn="{StaticResource HeaderButtonStyle}">
            <Setter Property="Background" Value="#217346"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#175231"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RefreshButtonStyle" TargetType="Button" BasedOn="{StaticResource HeaderButtonStyle}">
            <Setter Property="Background" Value="#7E8B99"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#5C6670"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DataGrid Premium Style -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F8FAFC"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E2E8F0"/>
            <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#ECEFF4"/>
            <Setter Property="Foreground" Value="#2D3748"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#CBD5E0"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#2D3748"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}" BorderThickness="0" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E2E8F0"/>
                    <Setter Property="Foreground" Value="#1A202C"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="Auto"/> <!-- Controls and Toolbar -->
            <RowDefinition Height="Auto"/> <!-- Modeless Progress -->
            <RowDefinition Height="*"/>    <!-- Data Grid Area -->
            <RowDefinition Height="Auto"/> <!-- Status Bar -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="RUKN" Foreground="#1B6ECE" FontSize="22" FontWeight="Bold"/>
                <TextBlock Text=" QUANT" Foreground="#2D3748" FontSize="22" FontWeight="Bold"/>
                <TextBlock Text=" — Quantity Extraction" Foreground="#718096" FontSize="14" VerticalAlignment="Bottom" Margin="8,0,0,3"/>
            </StackPanel>
        </Grid>

        <!-- Controls and Toolbar -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Action buttons -->
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button Content="Extract Quantities" Style="{StaticResource HeaderButtonStyle}" Click="BtnExtract_Click" Margin="0,0,8,0"/>
                <Button Content="Export Excel" Style="{StaticResource ExcelButtonStyle}" Click="BtnExport_Click" Margin="0,0,8,0"/>
                <Button Content="Refresh" Style="{StaticResource RefreshButtonStyle}" Click="BtnRefresh_Click"/>
            </StackPanel>

            <!-- Search box -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Search:" Foreground="#4A5568" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="TxtSearch" Width="200" Padding="8,5" BorderBrush="#CBD5E0" BorderThickness="1" GotFocus="TxtSearch_GotFocus" LostFocus="TxtSearch_LostFocus" TextChanged="TxtSearch_TextChanged">
                    <TextBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>
            </StackPanel>
        </Grid>

        <!-- Modeless Progress Bar -->
        <Grid Grid.Row="2" Margin="0,0,0,10" x:Name="GridProgress" Visibility="Collapsed">
            <ProgressBar x:Name="ProgressBarStatus" Height="6" Background="#E2E8F0" Foreground="#1B6ECE" IsIndeterminate="True" BorderThickness="0"/>
        </Grid>

        <!-- Data Grid Area (Sliding Panels Restored) -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/> <!-- Elements List -->
                <ColumnDefinition Width="Auto"/> <!-- Splitter -->
                <ColumnDefinition Width="1.5*"/> <!-- Summary List -->
            </Grid.ColumnDefinitions>

            <!-- Elements DataGrid -->
            <Border Grid.Column="0" Background="White" CornerRadius="8" BorderThickness="1" BorderBrush="#E2E8F0" Padding="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Detailed Element Quantities" Foreground="#4A5568" FontWeight="SemiBold" FontSize="13" Margin="5,5,0,8"/>
                    <DataGrid x:Name="DataGridElements" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="1.5*"/>
                            <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="1*"/>
                            <DataGridTextColumn Header="Family" Binding="{Binding Family}" Width="1*"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="1*"/>
                            <DataGridTextColumn Header="Revit ID" Binding="{Binding RevitId}" Width="0.8*"/>
                            <DataGridTextColumn Header="Length (m)" Binding="{Binding Length, StringFormat={}{0:F2}}" Width="0.8*"/>
                            <DataGridTextColumn Header="Area (m²)" Binding="{Binding Area, StringFormat={}{0:F2}}" Width="0.8*"/>
                            <DataGridTextColumn Header="Volume (m³)" Binding="{Binding Volume, StringFormat={}{0:F2}}" Width="0.8*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- GridSplitter (Sliding Panel Control) -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="#CBD5E0" ResizeBehavior="PreviousAndNext" Margin="5,0"/>

            <!-- Summary Panel -->
            <Border Grid.Column="2" Background="White" CornerRadius="8" BorderThickness="1" BorderBrush="#E2E8F0" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Text="Category Quantity Summary" Foreground="#4A5568" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,10"/>
                    
                    <DataGrid x:Name="DataGridSummary" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" BorderThickness="0" Background="Transparent">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="1.5*"/>
                            <DataGridTextColumn Header="Count" Binding="{Binding Count}" Width="0.8*"/>
                            <DataGridTextColumn Header="Vol (m³)" Binding="{Binding Volume, StringFormat={}{0:F1}}" Width="1*"/>
                            <DataGridTextColumn Header="Area (m²)" Binding="{Binding Area, StringFormat={}{0:F1}}" Width="1*"/>
                            <DataGridTextColumn Header="Length (m)" Binding="{Binding Length, StringFormat={}{0:F1}}" Width="1*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Grid Grid.Row="4" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Grid.Column="0">
                <TextBlock Text="Total Elements scanned: " Foreground="#718096" FontSize="12"/>
                <TextBlock x:Name="TxtTotalElements" Text="0" Foreground="#1B6ECE" FontWeight="SemiBold" FontSize="12"/>
            </StackPanel>
            <TextBlock x:Name="TxtStatus" Text="Scanned model to start..." Grid.Column="1" HorizontalAlignment="Center" Foreground="#718096" FontSize="12"/>
            <TextBlock x:Name="TxtTime" Text="Ready" Grid.Column="2" Foreground="#718096" FontSize="12"/>
        </Grid>
    </Grid>
</Window>
